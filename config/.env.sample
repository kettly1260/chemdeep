# ========================================
# Telegram Bot 配置
# ========================================
CHEMDEEP_TELEGRAM_TOKEN=
CHEMDEEP_TELEGRAM_PROXY=
CHEMDEEP_TELEGRAM_CHAT_ID=
CHEMDEEP_TELEGRAM_ALLOWED_CHAT_IDS=

# ========================================
# AI Provider 配置
# ========================================
# 可选值: openai | gemini | auto
# auto = 优先 OpenAI，失败则尝试 Gemini
CHEMDEEP_AI_PROVIDER=openai

# ========================================
# OpenAI 兼容 API（支持自定义地址）
# ========================================
CHEMDEEP_OPENAI_API_KEY=
CHEMDEEP_OPENAI_API_BASE=
CHEMDEEP_OPENAI_MODEL=
# CHEMDEEP_OPENAI_PROXY=

# 如果使用第三方兼容 API，修改 API_BASE，例如:
# CHEMDEEP_OPENAI_API_BASE=
# CHEMDEEP_OPENAI_MODEL=

# ========================================
# Google Gemini（可选）
# ========================================
CHEMDEEP_GEMINI_API_KEY=
CHEMDEEP_GEMINI_MODEL=
# CHEMDEEP_GEMINI_PROXY=

# ========================================
# AI 请求行为
# ========================================
# 请求超时时间（秒）
CHEMDEEP_AI_TIMEOUT=60
# 最大重试次数
# 最大重试次数


# ========================================
# OpenAlex 配置
# ========================================
# 留空使用免费公共池（低限额）
CHEMDEEP_OPENALEX_API_KEY=""
# 建议填写邮箱以加入 Polite Pool (更高限额)
CHEMDEEP_OPENALEX_MAILTO=""

# ========================================
# 路径配置
# ========================================
# 浏览器 Profile 目录（用于保存登录状态和 cookies）
CHEMDEEP_PROFILE_DIR=profiles/msedge

# 文献存储目录
CHEMDEEP_LIBRARY_DIR=data/library

# 报告输出目录
CHEMDEEP_REPORTS_DIR=data/reports

# ========================================
# 浏览器行为配置
# ========================================
# 每篇论文抓取间隔（秒），建议 60-120
CHEMDEEP_RATE_SECONDS=75

# 是否无头模式（0=显示浏览器，1=隐藏）
# 首次运行建议设为 0，方便手动处理登录和 Cloudflare
CHEMDEEP_HEADLESS=0

# 浏览器类型（msedge 使用系统 Edge）
CHEMDEEP_BROWSER_CHANNEL=msedge

# ========================================
# Google Scholar 搜索（实验性）
# ========================================
CHEMDEEP_ENABLE_GOOGLE_SCHOLAR=0
CHEMDEEP_GOOGLE_SCHOLAR_DELAY=5
